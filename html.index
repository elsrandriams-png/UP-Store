</section>

<!-- POPUP -->
<div id="paymentBox" class="hidden">
<div class="form">

<h2>💳 Paiement</h2>

<p><strong>Produit :</strong> <span id="productName"></span></p>

<p>Envoyez le paiement à :</p>
<h3>Madeleine<br>0373179561</h3>

<input type="text" id="uid" placeholder="Entrer UID">
<input type="text" id="ref" placeholder="Référence paiement">

<button onclick="confirmOrder()">Confirmer</button>
<button onclick="closeForm()">Annuler</button>

</div>
</div>

<script src="script.js"></script>
</body>
</html>

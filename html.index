<div class="item"><span>530+53💎=23,000Ar</span><button onclick="openForm('530+53💎=23,000Ar')">Acheter</button></div>
<div class="item"><span>730+63💎=27,600Ar</span><button onclick="openForm('730+63💎=27,600Ar')">Acheter</button></div>
